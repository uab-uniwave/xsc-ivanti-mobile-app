        await ViewModel.LoadFirstPageAsync(CancellationToken.None);

        // Map to Incident entities (temporary - replace with actual data from ViewModel)
        _incidents = GetSampleIncidents();
    }

    protected override void OnParametersSet()
    {
        _currentBreakpoint = CurrentBreakpoint;
        _isMobile = CurrentBreakpoint <= Breakpoint.Sm;
        _isTablet = CurrentBreakpoint == Breakpoint.Md;
        _isDense = CurrentBreakpoint <= Breakpoint.Md;
    }

    private void HandleSearchChanged(WsFavorite selectedSearch)
    {
        if (selectedSearch is not null)
        {
            Logger.LogInformation("Search changed to: {SearchName} (ID: {SearchId})", 
                selectedSearch.Name, selectedSearch.Id);

            Snackbar.Add($"Loading search: {selectedSearch.Name}", Severity.Info);

            // Call ViewModel to load grid data for the selected search
            _ = ViewModel.OnSearchChangedAsync(selectedSearch, CancellationToken.None);
        }
    }

