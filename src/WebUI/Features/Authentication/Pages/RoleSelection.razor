@page "/role-selection"
@rendermode InteractiveServer
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Medium" Class="d-flex align-center justify-center" Style="min-height: 100vh;">
    <MudPaper Elevation="4" Class="pa-8 rounded" Style="width: 100%; max-width: 600px;">
        <MudStack Spacing="4">

            <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">
                Select Role
            </MudText>

            <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">
                Please select a role to continue
            </MudText>

            <MudDivider />

            @if (!ViewModel.IsInitialized || ViewModel.IsLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="py-8">
                    <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.body1">
                        @(ViewModel.IsLoading ? "Selecting role..." : "Loading roles...")
                    </MudText>
                </MudStack>
            }
            else if (ViewModel.HasError)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">
                    @ViewModel.ErrorMessage
                </MudAlert>
                <MudButton Variant="Variant.Outlined"
                          Color="Color.Primary"
                          OnClick="@(() => ViewModel.LogoutAsync())"
                          FullWidth="true"
                          Class="rounded">
                    Back to Login
                </MudButton>
            }
            else if (ViewModel.AvailableRoles.Any())
            {
                <MudGrid Spacing="3">
                    @foreach (var role in ViewModel.AvailableRoles)
                    {
                        <MudItem xs="12" sm="6">
                            <MudCard Class="cursor-pointer hover-elevation"
                                    Elevation="@(role.IsSelected ? 4 : 2)"
                                    Style="@(role.IsSelected ? "border: 2px solid var(--mud-palette-primary);" : "")"
                                    @onclick="@(() => ViewModel.SelectRoleAsync(role))">
                                <MudCardContent>
                                    <MudStack Spacing="2" AlignItems="AlignItems.Center" Class="py-2">
                                        @if (role.IsAnalyst)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Engineering"
                                                    Size="Size.Large"
                                                    Color="Color.Primary" />
                                        }
                                        else if (role.IsSelfServiceMobile)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.PhoneAndroid"
                                                    Size="Size.Large"
                                                    Color="Color.Secondary" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Person"
                                                    Size="Size.Large"
                                                    Color="Color.Tertiary" />
                                        }

                                        <MudText Typo="Typo.h6" Align="Align.Center">
                                            @role.Name
                                        </MudText>

                                        @if (!string.IsNullOrEmpty(role.Id) && role.Id != role.Name)
                                        {
                                            <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary">
                                                @role.Id
                                            </MudText>
                                        }

                                        @if (role.IsSelected)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                                                Default
                                            </MudChip>
                                        }
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>

                <MudDivider Class="my-1" />

                <MudButton Variant="Variant.Text"
                          Color="Color.Secondary"
                          OnClick="@(() => ViewModel.LogoutAsync())"
                          FullWidth="true"
                          Class="rounded">
                    <MudIcon Icon="@Icons.Material.Filled.Logout" Class="mr-2" />
                    Back to Login
                </MudButton>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No roles available for your account.
                </MudAlert>
                <MudButton Variant="Variant.Outlined"
                          Color="Color.Primary"
                          OnClick="@(() => ViewModel.LogoutAsync())"
                          FullWidth="true"
                          Class="rounded">
                    Back to Login
                </MudButton>
            }

        </MudStack>
    </MudPaper>
</MudContainer>

<style>
    .hover-elevation:hover {
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
        transform: translateY(-2px);
        transition: all 0.2s ease-in-out;
    }

    .cursor-pointer {
        cursor: pointer;
    }
</style>
