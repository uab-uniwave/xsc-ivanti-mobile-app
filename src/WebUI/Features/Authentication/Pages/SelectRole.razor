@page "/select-role"
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Elevation="4" Class="pa-8">
        <MudStack Spacing="4">
            <MudText Typo="Typo.h4" Align="Align.Center">
                Select Workspace
            </MudText>

            <MudDivider />

            @if (ViewModel.IsLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="py-8">
                    <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                    <MudText Typo="Typo.body1">Loading workspaces...</MudText>
                </MudStack>
            }
            else if (ViewModel.HasError)
            {
                <MudAlert Severity="Severity.Error" Dense="true">
                    @ViewModel.ErrorMessage
                </MudAlert>
                <MudButton Variant="Variant.Outlined" 
                          Color="Color.Primary" 
                          OnClick="ViewModel.Logout"
                          FullWidth="true">
                    Back to Login
                </MudButton>
            }
            else if (ViewModel.Workspaces.Any())
            {
                <MudText Typo="Typo.body1" Class="mb-4">
                    Please select a workspace to continue:
                </MudText>

                <MudGrid>
                    @foreach (var workspace in ViewModel.Workspaces)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Class="cursor-pointer" 
                                    Elevation="2" 
                                    @onclick="@(() => ViewModel.SelectWorkspaceAsync(workspace))">
                                <MudCardContent>
                                    <MudStack Spacing="2" AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.Workspaces" 
                                                Size="Size.Large" 
                                                Color="Color.Primary" />
                                        <MudText Typo="Typo.h6" Align="Align.Center">
                                            @workspace.Name
                                        </MudText>
                                        @if (!string.IsNullOrEmpty(workspace.LayoutName))
                                        {
                                            <MudText Typo="Typo.caption" Align="Align.Center">
                                                @workspace.LayoutName
                                            </MudText>
                                        }
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>

                <MudDivider Class="my-4" />

                <MudButton Variant="Variant.Text" 
                          Color="Color.Secondary" 
                          OnClick="ViewModel.Logout"
                          FullWidth="true">
                    Logout
                </MudButton>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No workspaces available.
                </MudAlert>
                <MudButton Variant="Variant.Outlined" 
                          Color="Color.Primary" 
                          OnClick="ViewModel.Logout"
                          FullWidth="true">
                    Back to Login
                </MudButton>
            }
        </MudStack>
    </MudPaper>
</MudContainer>
