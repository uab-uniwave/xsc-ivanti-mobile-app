@inject IvantiNavigationService NavigationService

@if (NavigationService.IsLoading)
{
    <MudContainer Class="d-flex justify-center align-center pa-8">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </MudContainer>
}
else if (!string.IsNullOrEmpty(NavigationService.ErrorMessage))
{
    <MudAlert Severity="Severity.Error" Class="ma-2">
        @NavigationService.ErrorMessage
    </MudAlert>
}
else if (NavigationService.RoleWorkspaces?.Workspaces != null)
{
    <MudNavMenu>
        <MudText Typo="Typo.overline" Class="px-4 py-2 mud-text-secondary">
            Workspaces
        </MudText>

        @foreach (var workspace in NavigationService.RoleWorkspaces.Workspaces)
        {
            <MudNavLink Href="@GetWorkspaceUrl(workspace.Name)" 
                       Match="NavLinkMatch.Prefix" 
                       Icon="@GetWorkspaceIcon(workspace.Name)">
                @workspace.Name
            </MudNavLink>
        }
    </MudNavMenu>
}
else
{
    <MudAlert Severity="Severity.Info" Class="ma-2">
        No workspaces available
    </MudAlert>
}

@code {
    protected override void OnInitialized()
    {
        NavigationService.OnStateChanged += StateHasChanged;
    }

    public void Dispose()
    {
        NavigationService.OnStateChanged -= StateHasChanged;
    }

    private string GetWorkspaceUrl(string workspaceName)
    {
        // Map workspace IDs to URLs
        return workspaceName.ToLower() switch
        {
            "Incident" => "incident",
            "Task" => "task",
            "Service Request" => "servicerequest",
            "CI" => "ci",
            _ => workspaceName.ToLower()
        };
    }

    private string GetWorkspaceIcon(string workspaceName)
    {
        // Map workspace names to Material icons
        return workspaceName.ToLower() switch
        {
            var name when name.Contains("Incidens") => Icons.Material.Filled.Add,
            var name when name.Contains("Tass") => Icons.Material.Filled.MiscellaneousServices,
            var name when name.Contains("Service Request") => Icons.Material.Filled.ReportProblem,
            var name when name.Contains("CI") => Icons.Material.Filled.ChangeHistory,
            _ => Icons.Material.Filled.WorkOutline
        };
    }
}

@implements IDisposable


